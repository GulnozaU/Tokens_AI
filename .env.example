# TokenOS Backend
DATABASE_URL=sqlite:///./tokenos.db
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# Savings dashboard defaults (demo)
DEFAULT_MONTHLY_COST_BEFORE=50.0
DEFAULT_MONTHLY_COST_AFTER=18.0

# Skill promotion threshold (0-100)
SKILL_PROMOTION_THRESHOLD=80

# MCP server
TOKENOS_API_URL=http://localhost:8000/api

# Embedding (Gemini when GOOGLE_API_KEY set; hash fallback otherwise)
EMBEDDING_DIM=384
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-flash-latest
EMBEDDING_MODEL=text-embedding-004
