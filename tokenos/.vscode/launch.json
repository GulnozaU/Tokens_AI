{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run TokenOS Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/tokenos/extension"],
      "outFiles": ["${workspaceFolder}/tokenos/extension/dist/**/*.js"],
      "preLaunchTask": "compile-extension"
    }
  ]
}
